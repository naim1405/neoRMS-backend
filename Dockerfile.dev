# syntax=docker/dockerfile:1

ARG NODE_VERSION=24

FROM node:${NODE_VERSION}-alpine

WORKDIR /usr/src/app

# Install dependencies first for better layer caching during rebuilds.
COPY package*.json ./
RUN npm ci

# Prisma schema is needed for generate/migrate commands in dev startup.
COPY prisma ./prisma

EXPOSE 5000

CMD ["sh", "-c", "npx prisma migrate dev && npx prisma generate && npm run dev"]
