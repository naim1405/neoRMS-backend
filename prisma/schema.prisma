// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum UserRole {
    WAITER
    CHEF
    MANAGER
    CUSTOMER
    OWNER
}

// Product Enums

enum ProductStatus {
    AVAILABLE
    OUT_OF_STOCK
    DISCONTINUED
    DRAFT
}

enum Category {
    STARTER
    MAIN_COURSE
    DESSERT
    BEVERAGE
    SIDE
}

enum DietaryTag {
    VEGETARIAN
    VEGAN
    HALAL
    GLUTEN_FREE
    DAIRY_FREE
    NUT_FREE
}

enum VariantType {
    SMALL
    MEDIUM
    LARGE
    FAMILY
    SPECIAL
}

enum Currency {
    USD
    EUR
    GBP
    BDT
    INR
}

enum IngredientUnit {
    GRAM
    KILOGRAM
    LITER
    MILLILITER
    PIECE
}

// User model
model User {
    id              String   @id @default(uuid())
    email           String   @unique
    fullName        String
    role            UserRole
    avatar          String?
    password        String?
    authProvider    String   @default("local")
    isVerified      Boolean  @default(false)
    refreshToken    String?
    verificationOTP Int?

    Owner    Owner?
    Customer Customer?
    Chef     Chef?
    Waiter   Waiter?

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?
}

model Owner {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id])

    restaurants Restaurant[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
}

model Customer {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id])

    restaurants String[]
    reviews     Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    orders    Order[]

    @@index([userId])
}

model Chef {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id])

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Waiter {
    id     String @id @default(uuid())
    userId String

    user User @relation(fields: [userId], references: [id])

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Restaurant model
model Restaurant {
    id          String  @id @default(uuid())
    name        String
    tagline     String?
    description String?
    location    String?
    contactInfo String?
    bannerImage String?

    tenantId String @unique

    ownerId             String
    owner               Owner                 @relation(fields: [ownerId], references: [userId])
    chefs               Chef[]
    waiters             Waiter[]
    menuProducts        MenuProduct[]
    restaurantInventory RestaurantInventory[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Product model
model MenuProduct {
    id           String     @id @default(uuid())
    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    productTitle         String
    productDescription   String?
    estimatedCookingTime Int? // in minutes

    userRating Float? // average rating
    aiRating   Float?

    status        ProductStatus
    priceCurrency Currency
    category      Category
    dietaryTags   DietaryTag[]

    images String[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    reviews     Review[]
    ingredients MenuProductIngredient[]
    variants    Variant[]
    addons      Addon[]
    orders      OrderItem[]

    @@index([restaurantId])
}

model Review {
    id String @id @default(uuid())

    rating  Float
    comment String?

    customerId    String
    customer      Customer    @relation(fields: [customerId], references: [userId])
    menuProductId String
    menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])

    updatedAt DateTime @updatedAt
    createdAt DateTime @default(now())

    @@index([menuProductId])
    @@index([customerId])
}

// Catalog of all possible ingredients (restaurant-agnostic)
model InventoryIngredient {
    id   String         @id @default(uuid())
    name String         @unique
    unit IngredientUnit

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    restaurantInventories  RestaurantInventory[]
    menuProductIngredients MenuProductIngredient[]
}

// Tracks how much of each ingredient a specific restaurant has in stock
model RestaurantInventory {
    id                String @id @default(uuid())
    availableQuantity Float
    thresholdQuantity Float  @default(0)

    restaurantId String
    restaurant   Restaurant          @relation(fields: [restaurantId], references: [id])
    ingredientId String
    ingredient   InventoryIngredient @relation(fields: [ingredientId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([restaurantId, ingredientId])
    @@index([restaurantId])
    @@index([ingredientId])
}

// Defines how much of each ingredient a menu product requires
model MenuProductIngredient {
    id               String @id @default(uuid())
    requiredQuantity Float

    menuProductId String
    menuProduct   MenuProduct         @relation(fields: [menuProductId], references: [id])
    ingredientId  String
    ingredient    InventoryIngredient @relation(fields: [ingredientId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([menuProductId, ingredientId])
    @@index([menuProductId])
    @@index([ingredientId])
}

model Variant {
    id       String      @id @default(uuid())
    type     VariantType
    price    Float
    discount Float?

    menuProductId String
    menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])

    @@index([menuProductId])
}

model Addon {
    id    String @id @default(uuid())
    name  String
    price Float

    menuProductId String
    menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])

    @@index([menuProductId])
}

// Order 
enum OrderStatus {
    PENDING
    CONFIRMED
    PREPARING
    READY
    DELIVERED
    CANCELLED
}

enum PaymentMethod {
    CASH
    CARD
    MOBILE_PAYMENT
    ONLINE_PAYMENT
}

enum PaymentStatus {
    PENDING
    COMPLETED
    FAILED
    REFUNDED
}

// Order model
model Order {
    id                             String        @id @default(uuid())
    status                         OrderStatus   @default(PENDING)
    items                          OrderItem[]
    totalPrice                     Float
    paymentMethod                  PaymentMethod
    paymentStatus                  PaymentStatus @default(PENDING)
    notes                          String?
    estimatedDeliveryTimeInMinutes Int? // in minutes

    customerId String
    Customer   Customer @relation(fields: [customerId], references: [userId], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Order Item model
model OrderItem {
    id       String  @id @default(uuid())
    name     String
    quantity Int
    price    Float
    notes    String?

    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    menuItemId String
    menuItem   MenuProduct @relation(fields: [menuItemId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
