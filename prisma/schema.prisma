// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
    WAITER
    CHEF
    MANAGER
    CUSTOMER
    OWNER
}

// Product Enums

enum ProductStatus {
    AVAILABLE
    OUT_OF_STOCK
    DISCONTINUED
    DRAFT
}

enum Category {
    STARTER
    MAIN_COURSE
    DESSERT
    BEVERAGE
    SIDE
}

enum DietaryTag {
    VEGETARIAN
    VEGAN
    HALAL
    GLUTEN_FREE
    DAIRY_FREE
    NUT_FREE
}

enum VariantType {
    SMALL
    MEDIUM
    LARGE
    FAMILY
    SPECIAL
}

enum Currency {
    USD
    EUR
    GBP
    BDT
    INR
}

enum IngredientUnit {
    GRAM
    KILOGRAM
    LITER
    MILLILITER
    PIECE
}

// Tenant model
model Tenant {
    id                 String  @id @default(uuid())
    name               String
    slug               String  @unique
    plan               String  @default("free")
    subscriptionStatus String  @default("active")
    isActive           Boolean @default(true)

    ownerId             String
    owner               Owner                 @relation(fields: [ownerId], references: [userId])
    restaurant          Restaurant?
    chefs               Chef[]
    waiters             Waiter[]
    managers            Manager[]
    menuProducts        MenuProduct[]
    restaurantInventory RestaurantInventory[]
    tables              Table[]
    orders              Order[]
    reservations        Reservation[]
    coupons             Coupon[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?
}

// User model
model User {
    id              String   @id @default(uuid())
    email           String   @unique
    fullName        String
    role            UserRole
    avatar          String?
    password        String?
    authProvider    String   @default("local")
    isVerified      Boolean  @default(false)
    refreshToken    String?
    verificationOTP Int?

    Owner    Owner?
    Customer Customer?
    Chef     Chef?
    Waiter   Waiter?
    Manager  Manager?

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?
}

model Owner {
    id     String @id @default(uuid())
    userId String @unique
    user   User   @relation(fields: [userId], references: [id])

    tenants Tenant[]

    restaurants Restaurant[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@index([userId])
}

model Customer {
    id     String @id @default(uuid())
    userId String @unique
    user   User   @relation(fields: [userId], references: [id])

    restaurants String[]
    reviews     Review[]
    orders      Order[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    reservations Reservation[]
    couponUsages CouponUsage[]

    @@index([userId])
}

model Chef {
    id     String @id @default(uuid())
    userId String @unique
    user   User   @relation(fields: [userId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@index([userId])
    @@index([tenantId])
    @@index([restaurantId])
}

model Waiter {
    id     String @id @default(uuid())
    userId String @unique

    user User @relation(fields: [userId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@index([userId])
    @@index([tenantId])
    @@index([restaurantId])
}

model Manager {
    id     String @id @default(uuid())
    userId String @unique

    user User @relation(fields: [userId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@index([userId])
    @@index([tenantId])
    @@index([restaurantId])
}

// Restaurant model
model Restaurant {
    id          String  @id @default(uuid())
    name        String
    tagline     String?
    description String?
    location    String?
    contactInfo String?
    bannerImage String?

    tenantId String @unique
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    ownerId             String
    owner               Owner                 @relation(fields: [ownerId], references: [userId])
    chefs               Chef[]
    waiters             Waiter[]
    menuProducts        MenuProduct[]
    restaurantInventory RestaurantInventory[]
    managers            Manager[]
    tables              Table[]

    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean       @default(false)
    deletedBy     String?
    orders        Order[]
    coupons       Coupon[]
    reservations  Reservation[]

    @@index([tenantId])
    @@index([ownerId])
}

// Product model
model MenuProduct {
    id           String     @id @default(uuid())
    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    productTitle         String
    productDescription   String?
    estimatedCookingTime Int? // in minutes

    userRating Float? // average rating
    aiRating   Float?

    status        ProductStatus
    priceCurrency Currency
    basePrice     Float? // used when product has no variants
    category      Category
    dietaryTags   DietaryTag[]

    images String[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    // Relations
    reviews     Review[]
    ingredients MenuProductIngredient[]
    variants    Variant[]
    addons      Addon[]
    orders      OrderItem[]

    @@index([restaurantId])
    @@index([tenantId])
}

model Review {
    id String @id @default(uuid())

    rating    Float
    comment   String?
    sentiment String?

    customerId    String
    customer      Customer    @relation(fields: [customerId], references: [userId])
    orderId       String
    order         Order       @relation(fields: [orderId], references: [id])
    menuProductId String
    menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])

    updatedAt     DateTime @updatedAt
    createdAt     DateTime @default(now())
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@unique([customerId, orderId, menuProductId])
    @@index([menuProductId])
    @@index([customerId])
    @@index([orderId])
}

// Catalog of all possible ingredients (restaurant-agnostic)
model InventoryIngredient {
    id   String         @id @default(uuid())
    name String         @unique
    unit IngredientUnit

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    // Relations
    restaurantInventories  RestaurantInventory[]
    menuProductIngredients MenuProductIngredient[]
}

// Tracks how much of each ingredient a specific restaurant has in stock
model RestaurantInventory {
    id                String @id @default(uuid())
    availableQuantity Float
    thresholdQuantity Float  @default(0)

    restaurantId String
    restaurant   Restaurant          @relation(fields: [restaurantId], references: [id])
    ingredientId String
    ingredient   InventoryIngredient @relation(fields: [ingredientId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@unique([restaurantId, ingredientId])
    @@index([restaurantId])
    @@index([ingredientId])
    @@index([tenantId])
}

// Defines how much of each ingredient a menu product requires
model MenuProductIngredient {
    id               String @id @default(uuid())
    requiredQuantity Float

    menuProductId String
    menuProduct   MenuProduct         @relation(fields: [menuProductId], references: [id])
    ingredientId  String
    ingredient    InventoryIngredient @relation(fields: [ingredientId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@unique([menuProductId, ingredientId])
    @@index([menuProductId])
    @@index([ingredientId])
}

model Variant {
    id       String      @id @default(uuid())
    type     VariantType
    price    Float
    discount Float?

    menuProductId String
    menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    orderItems OrderItem[]

    @@unique([menuProductId, type])
    @@index([menuProductId])
}

model Addon {
    id    String @id @default(uuid())
    name  String
    price Float

    menuProductId String
    menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    orderItemAddons OrderItemAddon[]

    @@index([menuProductId])
}

enum OrderType {
    DINE_IN
    TAKEAWAY
    DELIVERY
}

// Order 
enum OrderStatus {
    PENDING
    CONFIRMED
    PREPARING
    READY
    DELIVERED
    CANCELLED
}

enum PaymentMethod {
    CASH
    CARD
    MOBILE_PAYMENT
    ONLINE_PAYMENT
}

enum PaymentStatus {
    PENDING
    COMPLETED
    FAILED
    REFUNDED
}

enum ReservationStatus {
    PENDING
    CONFIRMED
    SEATED
    COMPLETED
    CANCELLED
    NO_SHOW
}

model Table {
    id          String @id @default(uuid())
    tableNumber Int
    capacity    Int?

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    orders       Order[]
    reservations Reservation[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@unique([restaurantId, tableNumber])
    @@index([restaurantId])
    @@index([tenantId])
}

// Reservation model
model Reservation {
    id           String            @id @default(uuid())
    scheduledFor DateTime // the actual slot start
    duration     Int               @default(60) // in minutes
    partySize    Int
    status       ReservationStatus @default(PENDING)
    notes        String?
    contactPhone String?

    customerId   String
    customer     Customer   @relation(fields: [customerId], references: [userId])
    tableId      String
    table        Table      @relation(fields: [tableId], references: [id])
    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
    tenantId     String
    tenant       Tenant     @relation(fields: [tenantId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@index([tableId])
    @@index([customerId])
    @@index([restaurantId])
    @@index([tenantId])
    @@index([scheduledFor])
}

// Order model
model Order {
    id                             String        @id @default(uuid())
    status                         OrderStatus   @default(PENDING)
    items                          OrderItem[]
    totalPrice                     Float
    paymentMethod                  PaymentMethod
    paymentStatus                  PaymentStatus @default(PENDING)
    notes                          String?
    estimatedDeliveryTimeInMinutes Int? // in minutes

    customerId   String
    customer     Customer   @relation(fields: [customerId], references: [userId], onDelete: Restrict)
    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id])

    tableId   String?
    table     Table?    @relation(fields: [tableId], references: [id])
    orderType OrderType

    coupon      Coupon?      @relation(fields: [couponId], references: [id])
    couponId    String?
    couponUsage CouponUsage?
    reviews     Review[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@index([tenantId])
    @@index([restaurantId])
    @@index([customerId])
}

// Order Item model
model OrderItem {
    id          String       @id @default(uuid())
    name        String
    quantity    Int
    price       Float // snapshot of price at time of order
    notes       String?
    variantType VariantType? // snapshot of selected variant

    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    menuItemId String
    menuItem   MenuProduct @relation(fields: [menuItemId], references: [id])

    variantId String?
    variant   Variant? @relation(fields: [variantId], references: [id])

    selectedAddons OrderItemAddon[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?
}

model OrderItemAddon {
    id    String @id @default(uuid())
    name  String // snapshot
    price Float // snapshot

    orderItemId String
    orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

    addonId String?
    addon   Addon?  @relation(fields: [addonId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    lastUpdatedBy String?
    isDeleted     Boolean  @default(false)
    deletedBy     String?

    @@index([orderItemId])
}

enum DiscountType {
    PERCENTAGE
    AMOUNT
}

enum CouponStatus {
    ACTIVE
    EXPIRED
    REDEEMED
    INACTIVE
}

model Coupon {
    id             String       @id @default(uuid())
    code           String       @unique
    description    String?
    discount       Float
    discountType   DiscountType @default(PERCENTAGE)
    validFrom      DateTime
    validUntil     DateTime
    usageLimit     Int? // Total number of times the coupon can be used
    usedCount      Int          @default(0) // Number of times the coupon has been used
    minOrderAmount Float? // Minimum order total required to apply coupon
    maxDiscount    Float? // Cap on discount amount (for PERCENTAGE type)
    perUserLimit   Int? // Max times a single customer can use this coupon
    status         CouponStatus @default(ACTIVE)

    tenantId       String
    tenant         Tenant        @relation(fields: [tenantId], references: [id])
    restaurant     Restaurant?   @relation(fields: [restaurantId], references: [id])
    restaurantId   String?
    redeemedOrders Order[]
    customerUsages CouponUsage[]

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    isDeleted     Boolean  @default(false)
    deletedBy     String?
    lastUpdatedBy String?

    @@map("coupons")
}

model CouponUsage {
    id     String   @id @default(uuid())
    usedAt DateTime @default(now())

    couponId   String
    coupon     Coupon   @relation(fields: [couponId], references: [id])
    customerId String
    customer   Customer @relation(fields: [customerId], references: [userId])
    orderId    String   @unique
    order      Order    @relation(fields: [orderId], references: [id])

    @@unique([couponId, customerId, orderId])
    @@index([couponId])
    @@index([customerId])
}
