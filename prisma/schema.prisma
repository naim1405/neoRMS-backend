// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum UserRole {
    WAITER
    CHEF
    MANAGER
    CUSTOMER
    OWNER
}
// Order 

enum OrderStatus {
    PENDING
    CONFIRMED
    PREPARING
    READY
    DELIVERED
    CANCELLED
}

// New order type enum for dine-in vs takeaway
enum OrderType {
    DINE_IN
    TAKEAWAY
}



// Product Enums

enum ProductStatus {
  AVAILABLE
  OUT_OF_STOCK
  DISCONTINUED
  DRAFT
}

enum Category {
  STARTER
  MAIN_COURSE
  DESSERT
  BEVERAGE
  SIDE
}

enum DietaryTag {
  VEGETARIAN
  VEGAN
  HALAL
  GLUTEN_FREE
  DAIRY_FREE
  NUT_FREE
}

enum VariantType {
  SMALL
  MEDIUM
  LARGE
  FAMILY
  SPECIAL
}

enum Currency {
  USD
  EUR
  GBP
  BDT
  INR
}

// User model
model User {
    id              String   @id @default(uuid())
    email           String   @unique
    fullName        String
    role            UserRole
    avatar          String?
    password        String?
    authProvider    String   @default("local")
    isVerified      Boolean  @default(false)
    refreshToken    String?
    verificationOTP Int?

    // order
    orders          Order[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    associatedRestaurants AssociatedRestaurant[]
    reviews               Review[]
}

model AssociatedRestaurant {
    id            String     @id @default(uuid())
    userId        String
    restaurantId  String

    user          User       @relation(fields: [userId], references: [id])
    restaurant    Restaurant @relation(fields: [restaurantId], references: [id])

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@index([userId])
    @@index([restaurantId])
}

// Restaurant model
model Restaurant {
    id          String   @id @default(uuid())
    name        String
    tagline     String?
    description String?
    location    String?
    contactInfo String?
    bannerImage String?
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    // Relations
    menuProducts          MenuProduct[]
    associatedRestaurants AssociatedRestaurant[]
}


// Product model
model MenuProduct {
  id                    String        @id @default(uuid())
  restaurantId          String
  restaurant            Restaurant    @relation(fields: [restaurantId], references: [id])

  productTitle          String
  productDescription    String?
  estimatedCookingTime  Int?          // in minutes

  userRating            Float?        // average rating
  aiRating              Float?

  status                ProductStatus
  priceCurrency         Currency
  category              Category
  dietaryTags           DietaryTag[]

  images                String[]

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  reviews               Review[]
  ingredients           Ingredient[]
  variants              Variant[]
  addons                Addon[]

  @@index([restaurantId])
}

model Review {
  id            String      @id @default(uuid())
  menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])
  menuProductId String

  userId        String
  user          User        @relation(fields: [userId], references: [id])
  rating        Float
  comment       String?

  createdAt     DateTime    @default(now())

  @@index([menuProductId])
  @@index([userId])
}

model Ingredient {
  id            String      @id @default(uuid())
  name          String

  menuProduct   MenuProduct @relation(fields: [menuProductId], references: [id])
  menuProductId String

  @@index([menuProductId])
}

model Variant {
  id            String       @id @default(uuid())
  type          VariantType
  price         Float
  discount      Float?

  menuProduct   MenuProduct  @relation(fields: [menuProductId], references: [id])
  menuProductId String

  @@index([menuProductId])
}

model Addon {
  id            String       @id @default(uuid())
  name          String
  price         Float

  menuProduct   MenuProduct  @relation(fields: [menuProductId], references: [id])
  menuProductId String

  @@index([menuProductId])
}

// Order model
model Order {
    id                      String      @id @default(uuid())
    userId                  String
    user                    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    status                  OrderStatus @default(PENDING)
    orderType               OrderType   @default(DINE_IN)
    items                   OrderItem[]
    totalPrice              Float
    paymentMethod           String?
    paymentStatus           String?
    notes                   String?
    estimatedDeliveryTimeInMinutes   Int? // in minutes

    createdAt               DateTime    @default(now())
    updatedAt               DateTime    @updatedAt
}

// Order Item model
model OrderItem {
    id          String  @id @default(uuid())
    orderId     String
    order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
    menuItemId  String
    name        String
    quantity    Int
    price       Float
    notes       String?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}
